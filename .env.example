# --- Database ---
# Postgres connection string. Get one from Neon / Supabase / local.
DATABASE_URL=postgres://user:pass@host:5432/tinypa

# --- Auth.js ---
# Run: openssl rand -base64 32
AUTH_SECRET=
# In production this should be the public origin, e.g. https://tinypa.example.com
AUTH_URL=http://localhost:3000
# Same value, exposed client-side for deep links in emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email (Resend) ---
# https://resend.com/api-keys
RESEND_API_KEY=
# Any verified sender. For dev you can use the Resend sandbox: onboarding@resend.dev
MAIL_FROM="TinyPA <onboarding@resend.dev>"

# --- LLM (default NVIDIA NIM; override via LLM_BASE_URL / LLM_API_KEY) ---
# Default provider: https://build.nvidia.com -> Get API Key
NVIDIA_API_KEY=

# Alternative: Groq (often much faster than NIM). Sign up at https://console.groq.com.
# Set both to switch:
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=gsk_...
#   LLM_EXTRACT_MODEL=llama-3.1-8b-instant
#   LLM_DIGEST_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=
# LLM_API_KEY=

# Optional model overrides. Defaults (for NIM):
#   extract -> meta/llama-3.1-8b-instruct
#   digest  -> google/gemma-4-31b-it
# LLM_EXTRACT_MODEL=
# LLM_DIGEST_MODEL=

# --- Cron ---
# Any strong random string. Used to authenticate calls to /api/cron/*.
# Run: openssl rand -hex 32
CRON_SECRET=
